#!/usr/bin/env bash

branch="$(git symbolic-ref --short HEAD)"
retry=1
count=0

if ! git diff-index --quiet HEAD; then
    echo "Error: you have unstaged changes."
    exit 1
fi

while [[ "${retry}" -ne 0 ]]; do
    git pull --rebase=preserve origin "${branch}"
    git push origin "${branch}"
    retry=$?
    ((count++))
    echo
done

echo "${count}"
