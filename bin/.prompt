# based on https://github.com/nojhan/liquidprompt/

RED="\[$(tput setaf 1)\]"
BOLD="\[$(tput bold)\]"
RESET="\[$(tput sgr0)\]"

function __set_prompt {
    local error="$?"

    PS1="$(__jobs)\A \h \W ${RED}$(__error "${error}")${RESET}${BOLD}\$${RESET} "
    echo -n "$(printf '\e]0;%s %s\a' "${HOSTNAME}" "${PWD/#$HOME/\~}")"
}

function __error {
    local prompt=''
    local error="$1"

    if (( error != 0 )); then
        prompt="${error} "
    fi

    echo -n "${prompt}"
}

function __jobs {
    local prompt=''
    local jobs="$(jobs | wc -l)"

    if (( jobs != 0 )); then
        prompt="${jobs} "
    fi

    echo -n "${prompt}"
}

shopt -u promptvars
PROMPT_COMMAND=__set_prompt
