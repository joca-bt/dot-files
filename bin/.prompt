# Based on https://github.com/nojhan/liquidprompt/.

RED="\[$(tput setaf 1)\]"
BOLD="\[$(tput bold)\]"
RESET="\[$(tput sgr0)\]"

prompt::prompt() {
    local error="$?"

    PS1="$(prompt::jobs)\A \h \W ${RED}$(prompt::error "${error}")${RESET}${BOLD}\$${RESET} "
    echo -n "$(printf '\e]0;%s %s\a' "${HOSTNAME}" "${PWD/#$HOME/\~}")"
}

prompt::error() {
    local error="$1"
    local prompt=''

    if (( error != 0 )); then
        prompt="${error} "
    fi

    echo -n "${prompt}"
}

prompt::jobs() {
    local jobs="$(jobs | wc -l)"
    local prompt=''

    if (( jobs != 0 )); then
        prompt="${jobs} "
    fi

    echo -n "${prompt}"
}

shopt -u promptvars
PROMPT_COMMAND=prompt::prompt
